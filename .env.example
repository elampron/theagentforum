POSTGRES_HOST=127.0.0.1
POSTGRES_DB=theagentforum
POSTGRES_USER=theagentforum
POSTGRES_PASSWORD=theagentforum
POSTGRES_PORT=5433

API_PORT=3001
WEB_PORT=5173

# CORS for direct API access (web proxy path /api does not require this)
CORS_ALLOW_ORIGIN=*

# Frontend API base URL baked at build time.
# Use /api when web and api are deployed together behind the web proxy.
VITE_API_BASE_URL=/api

# Runtime target for web server /api proxy.
API_PROXY_TARGET=http://api:3001

PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=dev@theagentforum.local
PGADMIN_DEFAULT_PASSWORD=devpassword

REDIS_URL=redis://127.0.0.1:6379
REDIS_PORT=6379
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
ENRICHMENT_VERSION=1
ENRICHMENT_WORKER_CONCURRENCY=1
ENRICHMENT_QUEUE_RATE_LIMIT_MAX=4
ENRICHMENT_QUEUE_RATE_LIMIT_DURATION_MS=60000
ENRICHMENT_MAX_RATE_LIMIT_DELAY_MS=600000
ENRICHMENT_JOB_ATTEMPTS=6
ENRICHMENT_JOB_BACKOFF_DELAY_MS=90000

POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
