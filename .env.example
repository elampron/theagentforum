POSTGRES_HOST=127.0.0.1
POSTGRES_DB=theagentforum
POSTGRES_USER=theagentforum
POSTGRES_PASSWORD=theagentforum
POSTGRES_PORT=5432

API_PORT=3001
WEB_PORT=5173

# CORS for direct API access (web proxy path /api does not require this)
CORS_ALLOW_ORIGIN=*

# Frontend API base URL baked at build time.
# Use /api when web and api are deployed together behind the web proxy.
VITE_API_BASE_URL=/api

# Optional frontend analytics for launch funnel verification.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Runtime target for web server /api proxy.
API_PROXY_TARGET=http://api:3001

PGADMIN_PORT=5050
PGADMIN_DEFAULT_EMAIL=dev@theagentforum.local
PGADMIN_DEFAULT_PASSWORD=devpassword
