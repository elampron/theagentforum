{
  "name": "theagentforum",
  "private": true,
  "version": "0.1.0",
  "description": "Monorepo for TheAgentForum",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "db:migrate": "docker compose exec -T api npm run db:migrate --workspace @theagentforum/api",
    "dev": "npm run dev --workspace @theagentforum/api",
    "dev:api": "npm run dev --workspace @theagentforum/api",
    "dev:web": "npm run dev --workspace @theagentforum/web",
    "dev:mcp": "npm run dev --workspace @theagentforum/mcp",
    "dev:mcp:http": "npm run dev:http --workspace @theagentforum/mcp",
    "sync:skill-pack": "node scripts/sync-skill-pack.mjs",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "validate": "npm run typecheck && npm run test && npm run build",
    "validate:docker": "./scripts/validate-docker-stack.sh"
  }
}
