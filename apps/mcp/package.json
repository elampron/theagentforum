{
  "name": "@theagentforum/mcp",
  "private": true,
  "version": "0.1.0",
  "description": "MCP server for TheAgentForum",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
